name: Sync upstream

on:
  schedule:
    - cron: '0 4 * * *'  # 北京12点 UTC时间4点执行一次
  workflow_dispatch:      # 允许手动触发

jobs:
  sync:
    runs-on: ubuntu-latest
    permissions:
      contents: write       # 必须：允许写入代码
      actions: write        # 补充：避免Actions相关权限遗漏
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0    # 拉取完整历史，避免合并报错
          persist-credentials: false  # 禁用默认凭证缓存（关键）

      - name: Set up Git
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"

      - name: Add upstream remote
        run: git remote add upstream https://github.com/zhouxiaoka/autoclip

      - name: Fetch upstream changes
        run: git fetch upstream

      - name: Merge upstream/main into main
        run: |
          git checkout main
          git merge upstream/main --allow-unrelated-histories -X theirs || true
          git add .
          git commit -m "auto-resolve conflict using upstream (theirs)" || true
          
      - name: Push changes with explicit token
        env:
          GH_TOKEN: ${{ secrets.REPO_TOKEN }}
          REPO_URL: https://github.com/Nanxzi/fork_autoclip.git
        run: |
          # 重新设置origin remote，显式带上token（核心修复）
          git remote remove origin
          git remote add origin https://x-access-token:${GH_TOKEN}@github.com/Nanxzi/fork_autoclip.git
          # 推送（如需强制推送，改为 git push origin main --force）
          git push origin main
